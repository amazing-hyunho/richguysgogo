# --- Committee runtime toggles ---
USE_AGENT_DEBATE=1
KOREAN_FLOW_SOURCE=AUTO

# --- Model / agent behavior ---
AGENT_MODEL_BACKEND=openai
USE_LLM_AGENTS=0
LLM_TEMPERATURE=0.1
USE_LLM_CHAIR=0
CHAIR_OPENAI_MODEL=gpt-4.1-mini
CHAIR_LLM_TEMPERATURE=0.1
OPENAI_MODEL=
OPENAI_FALLBACK_MODELS=gpt-4.1,gpt-4.1-mini,gpt-4o,gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Paths ---
RUNS_BASE_DIR=runs
# LLM_TRACE_PATH is auto-set by run scripts when empty.

# Sensitive env vars intentionally excluded:
# - OPENAI_API_KEY
# - FRED_API_KEY
# - TELEGRAM_BOT_TOKEN
# - TELEGRAM_CHAT_ID
